{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "Playwright TypeScript E2E framework — Page Object Model, multi-browser, CI-ready",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "playwright test",
    "test:web": "playwright test --config=config/playwright.web.config.ts",
    "test:web:headed": "playwright test --config=config/playwright.web.config.ts --headed",
    "test:web:debug": "playwright test --config=config/playwright.web.config.ts --debug",
    "test:web-mobile": "playwright test --config=config/playwright.web-mobile.config.ts",
    "test:all": "npm run test:web && npm run test:web-mobile",
    "test:smoke": "playwright test --grep @smoke",
    "test:parallel": "playwright test --workers=4",
    "report:merge": "junit-report-merger -o reports/junit/merged-results.xml reports/junit/*-results.xml",
    "report:serve": "npx playwright show-report",
    "report:allure": "allure generate reports/allure-results -o reports/allure-report && allure open reports/allure-report",
    "analyze:failures": "ts-node utils/reporters/failure-classifier.ts",
    "analyze:failures:md": "ts-node utils/reporters/failure-classifier.ts --out reports/failure-report.md",
    "analyze:failures:json": "ts-node utils/reporters/failure-classifier.ts --json --out reports/failure-report.json",
    "validate:aaa": "ts-node utils/patterns/validate-all-tests.ts",
    "validate:timeouts": "ts-node utils/patterns/scan-for-timeouts.ts",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "type-check": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "automation",
    "quality-engineering"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "playwright": "^1.59.0",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.0",
    "@playwright/test": "^1.59.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^8.54.0",
    "junit-report-merger": "^6.0.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}