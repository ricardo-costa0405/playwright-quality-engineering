{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@pages/*": ["tests/web/pages/*"],
      "@fixtures/*": ["tests/web/fixtures/*", "tests/api/fixtures/*"],
      "@specs/*": ["tests/web/specs/*", "tests/api/specs/*"],
      "@utils/*": ["utils/*"],
      "@agents/*": ["agents/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "tests/**/*",
    "utils/**/*",
    "config/**/*",
    "agents/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports"
  ],
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "compilerOptions": {
      "module": "ES2020"
    }
  }
}
