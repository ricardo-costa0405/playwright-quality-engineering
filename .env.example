# =============================================================================
# Playwright Framework — Environment Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control — it is in .gitignore
# ✅  .env.example is safe to commit — it contains only placeholders
# =============================================================================

# -----------------------------------------------------------------------------
# Target Application
# -----------------------------------------------------------------------------
BASE_URL=https://www.saucedemo.com
API_URL=https://www.saucedemo.com/api

# -----------------------------------------------------------------------------
# Test Credentials
# Replace with your own values — never use real production credentials here
# -----------------------------------------------------------------------------
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# Additional SauceDemo test accounts
LOCKED_USER=locked_out_user
PROBLEM_USER=problem_user
PERFORMANCE_USER=performance_glitch_user

# -----------------------------------------------------------------------------
# Playwright Runtime
# -----------------------------------------------------------------------------
HEADLESS=true
SLOW_MO=0
WORKERS=4
TIMEOUT=30000
EXPECT_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Artifacts
# -----------------------------------------------------------------------------
SCREENSHOTS=only-on-failure
VIDEOS=on-first-retry
SCREENCAST_ENABLED=true
PRESERVE_SCREENCAST=false
TRACE=retain-on-failure

# -----------------------------------------------------------------------------
# Environment flags
# -----------------------------------------------------------------------------
# Set CI=true automatically in CI/CD pipelines (GitHub Actions sets this)
CI=false
DEBUG=false

# -----------------------------------------------------------------------------
# Reporting
# -----------------------------------------------------------------------------
# Allure, JUnit, and HTML reports are written to reports/ — see .gitignore

# -----------------------------------------------------------------------------
# MCP (Model Context Protocol)
# -----------------------------------------------------------------------------
MCP_ENABLED=false

# -----------------------------------------------------------------------------
# Agent Orchestration
# -----------------------------------------------------------------------------
AGENT_ORCHESTRATION_ENABLED=false
HEALING_AGENT_ENABLED=false
AUTO_HEAL_ON_FAILURE=false
