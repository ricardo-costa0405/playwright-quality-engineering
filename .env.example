# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy to .env and adjust values for your local setup:
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# .env.example is safe to commit — no real credentials here.
# =============================================================================

# -----------------------------------------------------------------------------
# Target Application
# -----------------------------------------------------------------------------
BASE_URL=https://www.saucedemo.com

# -----------------------------------------------------------------------------
# Test Credentials
# Use only test/demo account credentials here — never production values.
# -----------------------------------------------------------------------------
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# Additional SauceDemo user types (different behaviours for negative tests)
LOCKED_USER=locked_out_user
PROBLEM_USER=problem_user
PERFORMANCE_USER=performance_glitch_user

# -----------------------------------------------------------------------------
# Playwright Runtime
# -----------------------------------------------------------------------------
HEADLESS=true
SLOW_MO=0
WORKERS=4
TIMEOUT=30000
EXPECT_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Artifacts
# All output goes to reports/ — see .gitignore
# -----------------------------------------------------------------------------
SCREENSHOTS=only-on-failure
TRACE=retain-on-failure

# -----------------------------------------------------------------------------
# Environment flags
# CI is set automatically by GitHub Actions — no need to change it.
# -----------------------------------------------------------------------------
CI=false
DEBUG=false
